{
  "name": "know-yourself",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://yippee701.github.io/know-yourself/",
  "workspaces": [
    "packages/*",
    "apps/*",
    "skills/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @know-yourself/h5 run dev",
    "build": "pnpm --filter @know-yourself/h5 run build",
    "preview": "pnpm --filter @know-yourself/h5 run preview",
    "deploy": "pnpm --filter @know-yourself/h5 run deploy",
    "build:mp": "pnpm --filter @know-yourself/miniprogram run build:weapp",
    "dev:mp": "pnpm --filter @know-yourself/miniprogram run dev:weapp",
    "lint": "eslint .",
    "bootstrap": "pnpm install",
    "build:all": "pnpm -w -r run build",
    "lint:all": "pnpm -w -r --if-present run lint"
  },
  "packageManager": "pnpm@8.11.0",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0"
  }
}
